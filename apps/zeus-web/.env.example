# Zeus web — Vite env (copy to `apps/zeus-web/.env.local`; never commit secrets)

# --- Optional backends (see docs/RELAY_AND_CHAT_API.md) ---
# Relay: GET {base}/module
# VITE_ZEUS_RELAY_API_URL=http://localhost:8788

# Assistants: POST {base}/completion  { mode, messages }
# VITE_ZEUS_CHAT_API_URL=http://localhost:8788

# Mock server: npm run mock:api  (default port 8788)
# ZEUS_MOCK_API_PORT=8788

# PostHog — app.posthog.com → Project API Key
# VITE_POSTHOG_KEY=phc_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# MAMA API — social listening + PRISM
# VITE_MAMA_API_URL=https://mama.railway.app
