# Elevare Plugin - API Keys
# Copy this file to ~/.elevare-env and fill in your keys
# Then add to your shell: echo "source ~/.elevare-env" >> ~/.zshrc

# Apollo.io - Lead database (https://app.apollo.io/#/settings/integrations/api)
export APOLLO_API_KEY=""

# Instantly.ai - Email campaigns (https://app.instantly.ai/settings/integrations)
export INSTANTLY_API_KEY=""

# Google Ads (https://developers.google.com/google-ads/api/docs/first-call/oauth-cloud-project)
export GOOGLE_ADS_CLIENT_ID=""
export GOOGLE_ADS_CLIENT_SECRET=""
export GOOGLE_ADS_REFRESH_TOKEN=""
export GOOGLE_ADS_CUSTOMER_ID=""
export GOOGLE_ADS_DEVELOPER_TOKEN=""

# HubSpot CRM (https://developers.hubspot.com/docs/api/private-apps)
export HUBSPOT_API_KEY=""

# Reddit API (https://www.reddit.com/prefs/apps)
export REDDIT_CLIENT_ID=""
export REDDIT_CLIENT_SECRET=""
export REDDIT_USERNAME=""
export REDDIT_PASSWORD=""

# Twitter/X API (optional - for social listening)
export TWITTER_BEARER_TOKEN=""
