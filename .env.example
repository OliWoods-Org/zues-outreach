# Zeus Growth OS (zues-outreach Claude plugin) — API keys
# Copy to ~/.zeus-env (recommended) or ~/.elevare-env (legacy)
# Shell: echo "source ~/.zeus-env" >> ~/.zshrc
#
# Mission Control dashboard + workers are separate; this file is execution-layer only.
# Zeus build plan: docs/ZEUS_FINAL_BUILD_PLAN.md
#
# Optional future vars (workers / tiers — not all scripts consume yet):
# ZEUS_LISTEN_TIER=starter|pro|enterprise
# ZEUS_DAILY_TREND_POST_CAP=500

# Apollo.io - Lead database (https://app.apollo.io/#/settings/integrations/api)
export APOLLO_API_KEY=""

# Instantly.ai - Email campaigns (https://app.instantly.ai/settings/integrations)
export INSTANTLY_API_KEY=""

# Google Ads (https://developers.google.com/google-ads/api/docs/first-call/oauth-cloud-project)
export GOOGLE_ADS_CLIENT_ID=""
export GOOGLE_ADS_CLIENT_SECRET=""
export GOOGLE_ADS_REFRESH_TOKEN=""
export GOOGLE_ADS_CUSTOMER_ID=""
export GOOGLE_ADS_DEVELOPER_TOKEN=""

# HubSpot CRM (https://developers.hubspot.com/docs/api/private-apps)
export HUBSPOT_API_KEY=""

# Airtable — Elevar Outreach base (workspace: Zeus Outreach) — lead pipeline
# Full schema: docs/ELEVAR_OUTREACH_AIRTABLE.md
# https://airtable.com/create/tokens
#
# ISOLATION (other bases = scoring, algo, etc.): Create a PAT that grants access ONLY to this
# outreach base — do not use an "all bases" token here. Set AIRTABLE_BASE_ID to that base only.
# Optional fail-safe: same ID twice locks runs to one base (typo protection):
# export AIRTABLE_LOCK_TO_BASE_ID="$AIRTABLE_BASE_ID"
# Or block accidental use of known bases: export AIRTABLE_FORBIDDEN_BASE_IDS="appScoring...,appAlgo..."
#
# Base ID: from https://airtable.com/api for your base (starts with app...).
# Not the workspace ID (wsp...) — API calls use base ID only.
# export AIRTABLE_WORKSPACE_NOTE="wsp..."  # optional; human reference only, unused by scripts
export AIRTABLE_PAT=""
export AIRTABLE_BASE_ID=""
export AIRTABLE_TABLE="Leads"
# Optional: defaults to "Elevar Master Outreach"; set AIRTABLE_SKIP_CAMPAIGN=1 to omit Campaign field
export AIRTABLE_CAMPAIGN="Elevar Master Outreach"
# export AIRTABLE_MERGE_FIELD="Email"
# export AIRTABLE_FIELD_MAP='{"company":"Organization"}'

# Reddit API (https://www.reddit.com/prefs/apps)
export REDDIT_CLIENT_ID=""
export REDDIT_CLIENT_SECRET=""
export REDDIT_USERNAME=""
export REDDIT_PASSWORD=""

# Twitter/X API (optional - for social listening)
export TWITTER_BEARER_TOKEN=""
